# Database
POSTGRES_DB=chatdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Backend
JWT_SECRET=replace-with-strong-secret
JWT_TTL_MINUTES=1440
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=25
DB_CONN_MAX_LIFETIME_MINUTES=5
RATE_LIMIT_RPS=5
RATE_LIMIT_BURST=10

# Reverse Proxy / TLS
# Use your public domain in production, e.g. chat.example.com
DOMAIN=localhost
# Required for Let's Encrypt in production
ACME_EMAIL=admin@example.com

# Host bind ports (useful when routing with host Nginx)
BACKEND_HOST_BIND=127.0.0.1
BACKEND_HOST_PORT=8080
FRONTEND_HOST_BIND=127.0.0.1
FRONTEND_HOST_PORT=3000

# Frontend API base URL:
# - Leave empty for same-origin calls via Nginx (/api)
# - Or set an absolute URL, e.g. https://chat.example.com
NEXT_PUBLIC_API_BASE_URL=

# LLM
LLM_MODEL_NAME=hf.co/bartowski/Llama-3.2-3B-Instruct-GGUF:Q6_K
# For low-memory machines, consider: hf.co/bartowski/Llama-3.2-3B-Instruct-GGUF:Q4_K_M
# Larger context uses more memory; keep this around 2048-4096 on constrained hosts.
LLM_CTX_SIZE=4096
LLM_TIMEOUT_SECONDS=120
LLM_BASE_URL=http://model-runner.docker.internal/engines

# Required before starting compose stack:
# hf auth login
# docker model run --detach hf.co/bartowski/Llama-3.2-3B-Instruct-GGUF:Q6_K
